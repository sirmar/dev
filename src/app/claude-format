#!/usr/bin/env bash
# Claude Code PostToolUse hook — runs format on the edited file.
# Reads a Claude tool-use JSON object from stdin.
set -euo pipefail

abs="$(jq -r '.tool_input.file_path')"

dev_dir="$(dirname "$abs")"
while [[ "$dev_dir" != '/' && ! -f "$dev_dir/.dev" ]]; do
  dev_dir="$(dirname "$dev_dir")"
done
[[ "$dev_dir" == '/' ]] && exit 0

target="${abs#"$dev_dir"/}"

cd "$dev_dir" && dev format "$target" &>/dev/null || true
