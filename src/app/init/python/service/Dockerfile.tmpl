FROM ghcr.io/sirmar/dev-python:{{DEV_VERSION}} AS base
WORKDIR /workspace

FROM base AS deps
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --extra dev

FROM deps AS lint
ENTRYPOINT ["/usr/local/bin/lint-entrypoint.sh"]

FROM deps AS format
ENTRYPOINT ["/usr/local/bin/format-entrypoint.sh"]

FROM deps AS unit
ENTRYPOINT ["/usr/local/bin/unit-entrypoint.sh"]

FROM deps AS coverage
ENTRYPOINT ["/usr/local/bin/coverage-entrypoint.sh"]

FROM deps AS types
ENTRYPOINT ["/usr/local/bin/types-entrypoint.sh"]

FROM deps AS security
ENTRYPOINT ["/usr/local/bin/security-entrypoint.sh"]

FROM deps AS lock
ENTRYPOINT ["/usr/local/bin/lock-entrypoint.sh"]

FROM deps AS watch
EXPOSE 8000
ENTRYPOINT ["/usr/local/bin/watch-entrypoint.sh"]

FROM base AS prod
LABEL org.opencontainers.image.source=https://github.com/your-org/{{DEV_NAME}}
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --no-dev
COPY src/app/ src/app/
EXPOSE 8000
ENTRYPOINT ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
