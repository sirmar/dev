#!/usr/bin/env bash
# Claude Code PostToolUse hook — runs lint-dockerfile when Dockerfile is edited.
# Reads a Claude tool-use JSON object from stdin.
set -euo pipefail

abs="$(jq -r '.tool_input.file_path')"

[[ "$(basename "$abs")" == "Dockerfile" ]] || exit 0

dev_dir="$(dirname "$abs")"
while [[ "$dev_dir" != '/' && ! -f "$dev_dir/.dev" ]]; do
  dev_dir="$(dirname "$dev_dir")"
done
[[ "$dev_dir" == '/' ]] && exit 0

output="$(cd "$dev_dir" && dev lint-dockerfile 2>&1)" || {
  tail -n 20 <<<"$output" >&2
  exit 2
}
